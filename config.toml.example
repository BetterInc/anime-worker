# Anime Worker Configuration Example
# Copy to config.toml and fill in your details

server_url = "https://your-server.example.com"
worker_id = "worker-uuid-from-registration"
api_key = "aw_your_api_key_here"
worker_name = "My GPU Worker"

# Optional: Override default directories
# models_dir = "/path/to/models"        # Default: ~/.anime-worker/models
# python_path = "python3"                # Auto-detected if not set
# python_scripts_dir = "./python"        # Default: auto-detected near binary

# Optional: Intervals and timing
# heartbeat_interval_secs = 30           # Default: 30 seconds
# cleanup_interval_secs = 3600           # Default: 3600 (1 hour)
# retention_hours = 24                   # Default: 24 hours

# Optional: Enable streaming features
# enable_log_streaming = true            # Stream logs to server (default: false)
# enable_metrics_collection = true       # Collect GPU/RAM metrics (default: false)

# Worker Constraints (all optional)
[constraints]
# Resource limits - restrict what the worker reports to the server
# cpu_limit = 8              # Allocate only 8 cores (omit = use 90% of available)
# ram_limit_gb = 32.0        # Report only 32GB RAM (omit = use actual)
# disk_limit_gb = 500.0      # Report 500GB disk space (omit = use 90% of available)

# Model filtering - control which models this worker will handle
# max_model_size_gb = 30     # Don't download models larger than 30GB
# max_total_cache_gb = 100   # Keep cache under 100GB total

# Model allowlist/blocklist (use one or the other, not both)
# supported_models = ["wan22_ti2v_5b"]  # Only accept these models
# excluded_models = ["huge_model"]       # Never accept these models
